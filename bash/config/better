# Better Mode Toggle
# Provides a 'better' command to toggle aliases for modern tool replacements.

export BETTER=${BETTER:-false}

_update_better_mode() {
  if [[ "$BETTER" == "true" ]]; then
    # Cat -> Bat
    if command -v bat >/dev/null 2>&1; then
      alias cat='bat'
    fi
    
    # Ls -> Exa
    if command -v exa >/dev/null 2>&1; then
      alias ls='exa'
    fi

    # Grep -> Rg
    if command -v rg >/dev/null 2>&1; then
      alias grep='rg'
    fi

    # Find -> Fd
    if command -v fd >/dev/null 2>&1; then
      alias find='fd'
    fi

    # Top/Htop -> Btm
    if command -v btm >/dev/null 2>&1; then
      alias top='btm'
      alias htop='btm'
    fi

    # Du -> Dust
    if command -v dust >/dev/null 2>&1; then
      alias du='dust'
    fi

    # Ps -> Procs
    if command -v procs >/dev/null 2>&1; then
      alias ps='procs'
    fi

    # Df -> Duf
    if command -v duf >/dev/null 2>&1; then
      alias df='duf'
    fi
  else
    unalias cat 2>/dev/null
    unalias ls 2>/dev/null
    unalias grep 2>/dev/null
    unalias find 2>/dev/null
    unalias top 2>/dev/null
    unalias htop 2>/dev/null
    unalias du 2>/dev/null
    unalias ps 2>/dev/null
    unalias df 2>/dev/null
    
    # Restore basic aliases if they exist in alias/general
    # The general aliases might need to be re-applied.
    [[ -f "${HOME}/.config/bash/alias/general" ]] && source "${HOME}/.config/bash/alias/general"

    # Restore extra aliases if they exist in alias/extras
    [[ -f "${HOME}/.config/bash/extras/**/alias" ]] && source "${HOME}/.config/bash/extras/**/alias"
  fi
}

better() {
  if [[ "$BETTER" == "true" ]]; then
    export BETTER=false
    echo "Better Mode: OFF"
  else
    export BETTER=true
    echo "Better Mode: ON"
  fi
  _update_better_mode
  
  # Trigger a prompt refresh in some shells, though in Bash PS1 is evaluated every time.
  # We just need to make sure the PS1 variable uses the dynamic check.
}

# Keybinding: Ctrl+B to toggle better mode
# Note: Use bind -x to execute a bash function
bind -x '"\C-b": better'

# Initialize on load
_update_better_mode
